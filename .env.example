# EduLink Sup — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local
# Ne jamais committer .env.local

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://kcfpvnrgutkhakogbjip.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Edge Functions ────────────────────────────────────────────
# ⚠ Sensible — ne jamais exposer côté client
# Côté serveur uniquement (Edge Functions Supabase)
WEBHOOK_SECRET=your_webhook_secret_here

# ── Brevo (Email) ────────────────────────────────────────────
# Côté serveur uniquement (Edge Functions Supabase)
BREVO_API_KEY=your_brevo_api_key_here

# ── Vercel (déploiement) ─────────────────────────────────────
# Ces variables sont à configurer dans :
# Vercel Dashboard → Project → Settings → Environment Variables
# Elles sont injectées automatiquement au build

# ── Sentry (monitoring) ────────────────────────────────────
VITE_SENTRY_DSN=your_sentry_dsn_here
