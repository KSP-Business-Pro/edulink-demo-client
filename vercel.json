{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)",   "destination": "/api/$1" },
    { "source": "/login",      "destination": "/dist/index.html" },
    { "source": "/dashboard",  "destination": "/dist/index.html" },
    { "source": "/admin/(.*)", "destination": "/dist/index.html" },
    { "source": "/(.*)",       "destination": "/index_legacy.html" }
  ]
}
